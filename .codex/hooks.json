{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/session-start.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/session-start.ps1\"",
            "timeout": 15,
            "statusMessage": "加载{{PROJECT_NAME}}项目治理上下文"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/user-prompt-submit.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/user-prompt-submit.ps1\"",
            "timeout": 10,
            "statusMessage": "检查用户输入的项目治理上下文"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/stop-chat-summary.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/stop-chat-summary.ps1\"",
            "timeout": 15,
            "statusMessage": "检查实施收尾交接卡格式"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/post-edit-framework-check.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/post-edit-framework-check.ps1\"",
            "timeout": 20,
            "statusMessage": "改 framework 后快检索引一致性"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/pre-write-guard.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT_POSIX}}/能力资产/tools/hooks/codex/pre-write-guard.ps1\"",
            "timeout": 10,
            "statusMessage": "敏感写入(密钥)前置确认"
          }
        ]
      }
    ]
  }
}
